# ============================================================================
# .env.example — aumos-mlops-lifecycle
# Copy to .env and fill in values for local development.
# All production secrets must be stored in aumos-secrets-vault, never here.
# ============================================================================

# ---------------------------------------------------------------------------
# Core AumOS Settings (inherited from aumos_common.config.AumOSSettings)
# ---------------------------------------------------------------------------

AUMOS_SERVICE_NAME=aumos-mlops-lifecycle
AUMOS_ENVIRONMENT=development

# PostgreSQL connection string (asyncpg driver)
AUMOS_DATABASE__URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos

# Kafka broker list (comma-separated for multi-broker setups)
AUMOS_KAFKA__BROKERS=localhost:9092

# Redis connection URL (used for caching and rate limiting)
AUMOS_REDIS__URL=redis://localhost:6379/0

# Keycloak / OIDC settings
AUMOS_KEYCLOAK__SERVER_URL=http://localhost:8080
AUMOS_KEYCLOAK__REALM=aumos
AUMOS_KEYCLOAK__CLIENT_ID=aumos-mlops-lifecycle
AUMOS_KEYCLOAK__CLIENT_SECRET=change-me-in-production

# Observability
AUMOS_OTEL__ENDPOINT=http://localhost:4317
AUMOS_OTEL__ENABLED=false
AUMOS_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# MLOps Lifecycle Service Settings (AUMOS_MLOPS_ prefix)
# ---------------------------------------------------------------------------

# MLflow tracking server URL
AUMOS_MLOPS_MLFLOW_TRACKING_URI=http://localhost:5000

# MLflow artifact storage backend (S3, GCS, or local path)
AUMOS_MLOPS_MLFLOW_ARTIFACT_ROOT=./mlruns

# Feast feature store registry (local file path or GCS URI gs://bucket/registry.pb)
AUMOS_MLOPS_FEAST_REGISTRY_PATH=data/registry.db

# Feast offline store connection
AUMOS_MLOPS_FEAST_OFFLINE_STORE_TYPE=file

# Canary deployment settings
# Error rate (0.0-1.0) that triggers automatic rollback during canary progression
AUMOS_MLOPS_CANARY_ERROR_THRESHOLD=0.05
# Traffic percentage increment per canary progression step
AUMOS_MLOPS_CANARY_STEP_PERCENT=10
# Interval in seconds between canary progression checks
AUMOS_MLOPS_CANARY_PROGRESSION_INTERVAL_SECONDS=300

# Retraining job settings
# Maximum number of concurrent retraining jobs allowed per tenant
AUMOS_MLOPS_MAX_CONCURRENT_RETRAINING_JOBS=5
# Default timeout in seconds for a retraining job before marking it failed
AUMOS_MLOPS_RETRAINING_JOB_TIMEOUT_SECONDS=3600

# Feature store materialization settings
# Default batch size for feature materialization runs
AUMOS_MLOPS_FEAST_MATERIALIZATION_BATCH_SIZE=10000

# Model registry integration
# Base URL of the aumos-model-registry service
AUMOS_MLOPS_MODEL_REGISTRY_URL=http://localhost:8001

# Internal service-to-service API key for calling aumos-model-registry
AUMOS_MLOPS_MODEL_REGISTRY_API_KEY=change-me-in-production
